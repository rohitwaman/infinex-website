generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String
  tech        String
  imageUrl    String?
  liveUrl     String?
  createdAt   DateTime @default(now())
}