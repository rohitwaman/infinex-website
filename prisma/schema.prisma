generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Portfolio {
  id          String   @id @default(cuid())
  title       String
  description String
  tech        String
  imageUrl    String?
  liveUrl     String?
  createdAt   DateTime @default(now())
}

model Contact {
  id String @id @default(cuid())

  name    String
  email   String
  phone   String
  company String?
  message String

  status String @default("New")

  createdAt DateTime @default(now())
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String?
  author      String   @default("The Infinex Technologies")

  category    String   @default("Technology")

  published   Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}